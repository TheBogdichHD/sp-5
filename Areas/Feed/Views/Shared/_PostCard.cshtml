@model PostCardViewModel

<article class="bg-white shadow-sm p-6 @(Model.IsEvent ? "border-l-4 border-l-swamp-400" : string.Empty)">
    <div class="flex items-start space-x-3">
        <img src="@(string.IsNullOrWhiteSpace(Model.AuthorAvatarUrl) ? "/images/green-toad-logo.svg" : Model.AuthorAvatarUrl)"
             alt="@Model.AuthorDisplayName"
             class="w-16 h-16 rounded-full object-cover">
        <div class="flex-1">
            <div class="flex items-center space-x-2">
                <h4 class="font-semibold text-swamp-900">@Model.AuthorDisplayName</h4>
                <a href="/profile/@Model.AuthorUsername" class="text-sm text-swamp-500 hover:text-swamp-700">@@@Model.AuthorUsername</a>
                <span class="text-swamp-500">·</span>
                <a href="/feed/post/@Model.PostId" class="text-sm text-swamp-500 hover:text-swamp-700">@Model.CreatedAgo</a>
            </div>

            <p class="mt-2 text-swamp-700 leading-relaxed">@Html.Raw(Model.ContentHtml)</p>

            @if (!string.IsNullOrWhiteSpace(Model.MediaUrl))
            {
                if (Model.MediaType == "video")
                {
                    <video class="mt-4 w-full rounded-lg bg-slate-900" controls preload="metadata" poster="@Model.ThumbnailUrl">
                        <source src="@Model.MediaUrl" type="video/mp4">
                        Your browser does not support the video tag.
                    </video>
                }
                else
                {
                    <img class="mt-4 rounded-lg w-full object-cover" src="@Model.MediaUrl" alt="@(Model.AltText ?? "post media")">
                }
            }

            @if (Model.IsEvent)
            {
                <div class="mt-4 rounded-lg bg-swamp-50 border border-swamp-100 p-3 text-sm text-swamp-700">
                    <div class="font-semibold text-swamp-800">Upcoming Event</div>
                    <div>@Model.EventTime?.ToLocalTime().ToString("dd MMM HH:mm") · @Model.EventLocation</div>
                    @if (!string.IsNullOrWhiteSpace(Model.EventHostOrg))
                    {
                        <div class="text-swamp-500">Hosted by @Model.EventHostOrg</div>
                    }
                    @if (Model.EventRsvpCount.HasValue)
                    {
                        <div class="text-swamp-500">RSVP: @Model.EventRsvpCount</div>
                    }
                </div>
            }

            <div class="mt-4 flex flex-wrap items-center gap-5 text-swamp-500 text-sm">
                <a href="/feed/post/@Model.PostId" class="hover:text-swamp-700">@Model.AnswersCount Answers</a>
                <span>@Model.ReribbsCount Reribbs</span>
                <span>@Model.InteractionsCount Interactions</span>
            </div>
        </div>
    </div>
</article>
