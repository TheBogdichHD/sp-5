@model PostCardViewModel

<article class="bg-white shadow-sm p-6 @(Model.IsEvent ? "border-l-4 border-l-swamp-400" : string.Empty)">
    <div class="flex items-start space-x-3">
        <img src="@(string.IsNullOrWhiteSpace(Model.AvatarUrl) ? "/images/green-toad-logo.svg" : Model.AvatarUrl)"
             alt="@Model.DisplayName"
             class="w-16 h-16 rounded-full object-cover" />
        <div class="flex-1">
            <div class="flex items-center space-x-2">
                <h4 class="font-semibold text-swamp-900">@Model.DisplayName</h4>
                <a class="text-sm text-swamp-500 hover:text-swamp-700" href="/profile/@Model.Username">@@@Model.Username</a>
                <span class="text-swamp-500">·</span>
                <a class="text-sm text-swamp-500 hover:text-swamp-700" href="/feed/post/@Model.PostId">@Model.RelativeTime</a>
            </div>

            <p class="mt-2 text-swamp-700 leading-relaxed">@Html.Raw(Model.ContentWithLinks)</p>

            @if (Model.IsEvent)
            {
                <div class="mt-3 rounded-xl bg-swamp-50 border border-swamp-100 p-3">
                    <p class="text-sm text-swamp-800 font-semibold">Event</p>
                    <p class="text-sm text-swamp-700">@Model.EventLocation</p>
                    @if (Model.EventTime is DateTime eventTime)
                    {
                        <p class="text-sm text-swamp-500">@eventTime.ToLocalTime().ToString("dd MMM yyyy, HH:mm")</p>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.EventHostOrg))
                    {
                        <p class="text-sm text-swamp-500">Hosted by @Model.EventHostOrg</p>
                    }
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(Model.MediaUrl))
            {
                if (Model.MediaType == "video")
                {
                    <video class="mt-4 w-full rounded-xl bg-black" controls preload="metadata" poster="@Model.ThumbnailUrl">
                        <source src="@Model.MediaUrl" type="video/mp4" />
                    </video>
                }
                else
                {
                    <img src="@Model.MediaUrl" alt="@Model.AltText" class="mt-4 w-full rounded-xl object-cover" />
                }
            }

            <div class="mt-4 flex items-center space-x-6 text-swamp-500">
                <a class="flex items-center space-x-2 hover:text-swamp-600" href="/feed/post/@Model.PostId">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                    </svg>
                    <span>@Model.Interactions.Comments Answers</span>
                </a>

                <span class="flex items-center space-x-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                    </svg>
                    <span>@Model.Interactions.Reribbs Reribbs</span>
                </span>

                <span class="flex items-center space-x-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
                    </svg>
                    <span>@Model.Interactions.Likes</span>
                </span>

                @if (Model.IsEvent)
                {
                    <span class="flex items-center space-x-2">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10m-11 9h12a2 2 0 002-2V7a2 2 0 00-2-2H6a2 2 0 00-2 2v11a2 2 0 002 2z"></path>
                        </svg>
                        <span>@(Model.EventRsvpCount ?? Model.Interactions.Rsvps) RSVP</span>
                    </span>
                }
            </div>

            @if (Model.Tags.Count > 0)
            {
                <div class="mt-3 flex flex-wrap gap-2">
                    @foreach (var tag in Model.Tags)
                    {
                        <a class="rounded-full px-3 py-1 text-xs bg-swamp-100 text-swamp-700 hover:bg-swamp-200"
                           href="/ponds/@tag">#@tag</a>
                    }
                </div>
            }
        </div>
    </div>
</article>
