@model ProfilePageViewModel
@{
    ViewData["Title"] = $"Profile @{Model.Username}";
}

<div class="py-4">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-4 gap-0 lg:divide-x sm:divide-y">
            <aside class="lg:col-span-1 bg-white">
                <div class="p-6 pb-0">
                    <div class="flex space-x-3">
                        <img src="@(string.IsNullOrWhiteSpace(Model.AvatarUrl) ? "/images/green-toad-logo.svg" : Model.AvatarUrl)" alt="@Model.DisplayName" class="w-16 h-16 rounded-full object-cover">
                        <div class="flex-1">
                            <h4 class="font-semibold text-swamp-900">@Model.DisplayName</h4>
                            <a href="/profile/@Model.Username" class="text-sm text-swamp-500 hover:text-swamp-700">@@@Model.Username</a>
                        </div>
                    </div>
                </div>

                <div class="p-6 space-y-4">
                    <button type="button" class="flex items-center bg-swamp-500 text-white space-x-2 p-2 px-4 rounded-full hover:bg-swamp-600">
                        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M19 14V22H2.99997V4H13"></path>
                            <path d="M17.4608 4.03921C18.2418 3.25817 19.5082 3.25816 20.2892 4.03921L20.9608 4.71079C21.7418 5.49184 21.7418 6.75817 20.9608 7.53921L11.5858 16.9142C11.2107 17.2893 10.702 17.5 10.1716 17.5L7.5 17.5L7.5 14.8284C7.5 14.298 7.71071 13.7893 8.08579 13.4142L17.4608 4.03921Z"></path>
                            <path d="M16.25 5.25L19.75 8.75"></path>
                        </svg>
                        <span>New Ribbit</span>
                    </button>

                    <a href="/feed" class="p-1 text-swamp-900 flex items-center space-x-2 hover:bg-swamp-50 rounded-lg">
                        <svg class="w-8 h-8" fill="currentColor" viewBox="-81.92 -81.92 675.84 675.84">
                            <path d="M163.575,120.725c-5.855,0-10.601,4.747-10.601,10.601c0,6.132-4.993,11.12-11.131,11.12 c-6.132,0-11.121-4.988-11.121-11.12c0-5.854-4.746-10.601-10.601-10.601s-10.601,4.747-10.601,10.601 c0,17.823,14.501,32.323,32.324,32.323c17.829,0,32.334-14.501,32.334-32.323C174.177,125.472,169.431,120.725,163.575,120.725z"></path>
                            <path d="M392.821,120.725c-5.855,0-10.601,4.747-10.601,10.601c0,6.132-4.993,11.12-11.131,11.12 c-6.132,0-11.121-4.988-11.121-11.12c0-5.854-4.746-10.601-10.601-10.601s-10.601,4.747-10.601,10.601 c0,17.823,14.501,32.323,32.324,32.323c17.829,0,32.334-14.501,32.334-32.323C403.422,125.472,398.676,120.725,392.821,120.725z"></path>
                            <path d="M228.785,149.518c-5.855,0-10.601,4.747-10.601,10.601v2.809c0,5.854,4.746,10.601,10.601,10.601 s10.601-4.747,10.601-10.601v-2.809C239.386,154.265,234.64,149.518,228.785,149.518z"></path>
                            <path d="M279.947,149.518c-5.855,0-10.601,4.747-10.601,10.601v2.809c0,5.854,4.746,10.601,10.601,10.601 s10.601-4.747,10.601-10.601v-2.809C290.549,154.265,285.802,149.518,279.947,149.518z"></path>
                        </svg>
                        <h3 class="text-lg font-semibold">Swamp</h3>
                    </a>
                    <a href="#" class="p-1 text-swamp-900 flex items-center space-x-2 hover:bg-swamp-50 rounded-lg">
                        <svg class="w-8 h-8" fill="currentColor" viewBox="-43.32 -43.32 327.29 327.29">
                            <path d="m218.787,119.069c-7.552-18.233-23.021-35.615-43.56-48.944-5.611-3.642-11.369-6.826-17.027-9.48 0.001-0.074 0.005-0.148 0.005-0.222 0-15.537-9.405-28.913-22.818-34.749l12.87-12.87c2.929-2.929 2.929-7.678 0-10.606-2.93-2.929-7.678-2.929-10.607,0l-17.237,17.237-17.068-17.068c-2.93-2.929-7.678-2.929-10.607-8.88178e-16-2.929,2.929-2.929,7.678 0,10.606l12.644,12.644c-13.478,5.809-22.94,19.221-22.94,34.805 0,0.074 0.004,0.148 0.005,0.223-5.659,2.654-11.417,5.839-17.029,9.481-20.537,13.329-36.006,30.711-43.558,48.943-8.021,19.364 1.207,41.645 20.573,49.667 4.648,1.925 9.538,2.901 14.534,2.901 6.008-0.001 11.758-1.412 16.9-3.96 9.77,16.056 27.176,26.038 46.456,26.038 19.279,0 36.686-9.981 46.456-26.036 5.142,2.546 10.893,3.958 16.901,3.958 4.996,0 9.886-0.976 14.534-2.901 19.366-8.022 28.595-30.303 20.573-49.667z"></path>
                        </svg>
                        <h3 class="text-lg font-semibold">Events</h3>
                    </a>
                    <a href="/ponds/StudySwamp" class="p-1 text-swamp-900 flex items-center space-x-2 hover:bg-swamp-50 rounded-lg">
                        <svg class="w-8 h-8" fill="currentColor" viewBox="-122.88 -122.88 757.76 757.76">
                            <path d="M452.09,335.122c62.386-69.965,60.006-177.603,59.867-182.309c-0.255-8.712-7.161-15.767-15.864-16.21 c-2.307-0.116-34.685-1.557-74.997,6.427c-7.934-39.686-21.397-68.089-22.046-69.442c-3.695-7.715-12.621-11.393-20.681-8.529 c-1.409,0.502-30.793,11.089-64.301,33.391c-22.136-33.013-45.055-53.88-46.902-55.536c-6.353-5.7-15.98-5.7-22.333,0 c-1.847,1.658-24.767,22.523-46.902,55.536c-33.507-22.302-62.891-32.891-64.3-33.392c-8.061-2.866-16.983,0.815-20.681,8.529 c-0.649,1.353-14.111,29.756-22.046,69.442c-40.312-7.986-72.689-6.543-74.996-6.426c-8.706,0.441-15.61,7.497-15.865,16.21 c-0.138,4.706-2.518,112.345,59.867,182.309c-25.548,10.116-54.712,27.242-54.712,54.639c0,26.751,27.147,48.071,80.688,63.368 c45.665,13.047,106.079,20.232,170.114,20.232c64.035,0,124.449-7.185,170.114-20.232c53.54-15.297,80.688-36.617,80.688-63.368 C506.802,362.378,477.675,345.252,452.09,335.122z"></path>
                        </svg>
                        <h3 class="text-lg font-semibold">Ponds</h3>
                    </a>

                    <ul class="p-1 space-y-3">
                        <li class="p-1 hover:bg-swamp-50 rounded-lg">
                            <a href="/ponds/StudySwamp" class="flex items-center space-x-2">
                                <span class="w-2 h-2 bg-swamp-400 rounded-full"></span>
                                <span class="text-swamp-700">#StudySwamp</span>
                            </a>
                        </li>
                        <li class="p-1 hover:bg-swamp-50 rounded-lg">
                            <a href="/ponds/CampusLife" class="flex items-center space-x-2">
                                <span class="w-2 h-2"></span>
                                <span class="text-swamp-700">#CampusLife</span>
                            </a>
                        </li>
                    </ul>
                </div>
            </aside>

            <main class="lg:col-span-2 divide-y bg-white">
                <div class="relative overflow-hidden">
                    <div class="h-48 bg-swamp-800 relative">
                        <div class="absolute inset-0 bg-gradient-to-b from-swamp-600 to-swamp-200"></div>
                        <div class="absolute -bottom-12 left-6 z-10">
                            <div class="w-32 h-32 rounded-full border-4 border-swamp-600 bg-swamp-800 overflow-hidden shadow-xl">
                                <img src="@(string.IsNullOrWhiteSpace(Model.AvatarUrl) ? "/images/green-toad-logo.svg" : Model.AvatarUrl)" class="w-full h-full object-cover" alt="Profile avatar">
                            </div>
                        </div>
                    </div>

                    <div class="pt-24 pb-8 px-6 min-h-48">
                        <div class="flex justify-between items-start">
                            <div>
                                <h1 class="text-2xl font-bold text-swamp-900">@Model.DisplayName</h1>
                                <p class="text-swamp-500">@@@Model.Username</p>
                            </div>
                            <button type="button" class="px-4 p-2 flex items-center space-x-1 bg-swamp-500 text-white rounded-full hover:bg-swamp-600 transition-all">
                                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                                    <path fill-rule="evenodd" clip-rule="evenodd" d="M12.0002 8C9.79111 8 8.00024 9.79086 8.00024 12C8.00024 14.2091 9.79111 16 12.0002 16C14.2094 16 16.0002 14.2091 16.0002 12C16.0002 9.79086 14.2094 8 12.0002 8ZM10.0002 12C10.0002 10.8954 10.8957 10 12.0002 10C13.1048 10 14.0002 10.8954 14.0002 12C14.0002 13.1046 13.1048 14 12.0002 14C10.8957 14 10.0002 13.1046 10.0002 12Z"></path>
                                    <path fill-rule="evenodd" clip-rule="evenodd" d="M11.2867 0.5C9.88583 0.5 8.6461 1.46745 8.37171 2.85605L8.29264 3.25622C8.10489 4.20638 7.06195 4.83059 6.04511 4.48813L5.64825 4.35447C4.32246 3.90796 2.83873 4.42968 2.11836 5.63933L1.40492 6.83735C0.67773 8.05846 0.954349 9.60487 2.03927 10.5142L2.35714 10.7806C3.12939 11.4279 3.12939 12.5721 2.35714 13.2194L2.03927 13.4858C0.954349 14.3951 0.67773 15.9415 1.40492 17.1626L2.11833 18.3606C2.83872 19.5703 4.3225 20.092 5.64831 19.6455L6.04506 19.5118C7.06191 19.1693 8.1049 19.7935 8.29264 20.7437L8.37172 21.1439C8.6461 22.5325 9.88584 23.5 11.2867 23.5H12.7136C14.1146 23.5 15.3543 22.5325 15.6287 21.1438L15.7077 20.7438C15.8954 19.7936 16.9384 19.1693 17.9553 19.5118L18.3521 19.6455C19.6779 20.092 21.1617 19.5703 21.8821 18.3606L22.5955 17.1627C23.3227 15.9416 23.046 14.3951 21.9611 13.4858L21.6432 13.2194C20.8709 12.5722 20.8709 11.4278 21.6432 10.7806L21.9611 10.5142C23.046 9.60489 23.3227 8.05845 22.5955 6.83732L21.8821 5.63932C21.1617 4.42968 19.678 3.90795 18.3522 4.35444L17.9552 4.48814C16.9384 4.83059 15.8954 4.20634 15.7077 3.25617L15.6287 2.85616C15.3543 1.46751 14.1146 0.5 12.7136 0.5H11.2867Z"></path>
                                </svg>
                                <span>Settings</span>
                            </button>
                        </div>

                        <div class="mt-4 flex gap-6 text-swamp-700">
                            <div><span class="text-swamp-400 font-medium">@Model.Following</span> Following</div>
                            <div><span class="text-swamp-400 font-medium">@Model.Followers</span> Followers</div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(Model.Bio))
                        {
                            <p class="mt-4 text-swamp-700 leading-relaxed">@Model.Bio</p>
                        }
                    </div>

                    <div class="mt-2 flex gap-4 items-center px-2 border-t border-swamp-100">
                        <button type="button" class="p-2 pl-4 pr-4 text-swamp-700 border-b-2 border-swamp-500">Ribbits</button>
                        <button type="button" class="p-2 pl-4 pr-4 text-swamp-500 hover:text-swamp-700">Ponds</button>
                        <button type="button" class="p-2 pl-4 pr-4 text-swamp-500 hover:text-swamp-700">Replies</button>
                        <button type="button" class="p-2 pl-4 pr-4 text-swamp-500 hover:text-swamp-700">Media</button>
                    </div>
                </div>

                @if (Model.Posts.Count == 0)
                {
                    <div class="p-6 text-swamp-700">No posts yet.</div>
                }
                else
                {
                    @foreach (var post in Model.Posts)
                    {
                        <partial name="~/Areas/Feed/Views/Shared/_PostCard.cshtml" model="post" />
                    }
                }
            </main>

            <aside class="lg:col-span-1 bg-white">
                <div class="p-6 pb-0">
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <svg class="w-5 h-5 text-swamp-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                            </svg>
                        </div>
                        <input type="text" placeholder="Search" class="w-full pl-10 pr-4 py-2 bg-swamp-100 rounded-full border-none focus:ring-2 focus:ring-swamp-400">
                    </div>
                </div>

                <div class="p-6">
                    <h3 class="text-lg font-semibold text-swamp-900 mb-4">Trending Ponds</h3>
                    <ul class="space-y-4">
                        @foreach (var pond in Model.TrendingPonds)
                        {
                            <li>
                                <a href="/ponds/@pond.TagName" class="flex items-center space-x-3 group">
                                    <div class="w-8 h-8 bg-swamp-100 rounded-lg flex items-center justify-center">
                                        <svg class="text-swamp-600 w-5 h-5" fill="currentColor" viewBox="-122.88 -122.88 757.76 757.76">
                                            <path d="M452.09,335.122c62.386-69.965,60.006-177.603,59.867-182.309c-0.255-8.712-7.161-15.767-15.864-16.21 c-2.307-0.116-34.685-1.557-74.997,6.427c-7.934-39.686-21.397-68.089-22.046-69.442c-3.695-7.715-12.621-11.393-20.681-8.529 c-1.409,0.502-30.793,11.089-64.301,33.391c-22.136-33.013-45.055-53.88-46.902-55.536c-6.353-5.7-15.98-5.7-22.333,0 c-1.847,1.658-24.767,22.523-46.902,55.536c-33.507-22.302-62.891-32.891-64.3-33.392c-8.061-2.866-16.983,0.815-20.681,8.529 c-0.649,1.353-14.111,29.756-22.046,69.442c-40.312-7.986-72.689-6.543-74.996-6.426c-8.706,0.441-15.61,7.497-15.865,16.21 c-0.138,4.706-2.518,112.345,59.867,182.309c-25.548,10.116-54.712,27.242-54.712,54.639c0,26.751,27.147,48.071,80.688,63.368 c45.665,13.047,106.079,20.232,170.114,20.232c64.035,0,124.449-7.185,170.114-20.232c53.54-15.297,80.688-36.617,80.688-63.368 C506.802,362.378,477.675,345.252,452.09,335.122z"></path>
                                        </svg>
                                    </div>
                                    <div>
                                        <h4 class="font-medium text-swamp-900 group-hover:text-swamp-600">#@pond.TagName</h4>
                                        <p class="text-sm text-swamp-500">@pond.RecentPosts posts</p>
                                    </div>
                                </a>
                            </li>
                        }
                    </ul>
                </div>

                <div class="p-6 pt-0">
                    <h3 class="text-lg font-semibold text-swamp-900 mb-4">Upcoming Fireflies</h3>
                    <div class="space-y-4">
                        <div class="flex items-start space-x-3">
                            <div class="w-12 flex-shrink-0 text-center">
                                <div class="text-sm font-semibold text-swamp-600">APR</div>
                                <div class="text-2xl font-bold text-swamp-900">13</div>
                            </div>
                            <div>
                                <h4 class="font-medium text-swamp-900">Profile Showcase</h4>
                                <p class="text-sm text-swamp-500">Greenswamp Hub · 6PM</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="p-6">
                    <div class="flex items-start space-x-2 text-swamp-600">
                        <a href="/contact" class="hover:text-swamp-800">Contact</a>
                        <span>•</span>
                        <a href="/privacy" class="hover:text-swamp-800">Privacy</a>
                        <span>•</span>
                        <a href="/tos" class="hover:text-swamp-800">Terms</a>
                    </div>
                </div>
            </aside>
        </div>
    </div>
</div>
