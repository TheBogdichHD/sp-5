@page "/contact"
@model Lab5.Areas.Site.Pages.ContactModel
@{
    ViewData["Title"] = "Greenswamp - Contact";
}

<section class="rounded-xl shadow-sm p-8">
    <div class="max-w-2xl mx-auto">
        <div class="text-center mb-8">
            <h2 class="text-3xl font-bold text-swamp-900 mb-2">
                Swamp Mail
            </h2>
            <p class="text-swamp-700">Send a message that'll hop straight to our team</p>
        </div>

        @if (Model.IsSubmitted)
        {
            <div class="mb-6 rounded-lg bg-swamp-100 text-swamp-800 px-4 py-3">
                Message sent successfully.
            </div>
        }

        <form method="post" class="space-y-6">
            <div asp-validation-summary="ModelOnly" class="text-red-600 text-sm"></div>

            <div>
                <label asp-for="Input.Name" class="block text-sm font-medium text-swamp-700 mb-1">Your Name</label>
                <input asp-for="Input.Name"
                       class="w-full px-4 py-2 border border-swamp-200 rounded-lg focus:ring-2 focus:ring-swamp-400 focus:border-transparent"
                       placeholder="Viggo The Frogger" />
                <span asp-validation-for="Input.Name" class="text-red-600 text-sm"></span>
            </div>

            <div>
                <label asp-for="Input.Email" class="block text-sm font-medium text-swamp-700 mb-1">Your Email</label>
                <input asp-for="Input.Email"
                       class="w-full px-4 py-2 border border-swamp-200 rounded-lg focus:ring-2 focus:ring-swamp-400 focus:border-transparent"
                       placeholder="croak@swamp.edu" />
                <span asp-validation-for="Input.Email" class="text-red-600 text-sm"></span>
            </div>

            <div>
                <label asp-for="Input.Subject" class="block text-sm font-medium text-swamp-700 mb-1">Message Topic</label>
                <input asp-for="Input.Subject"
                       class="w-full px-4 py-2 border border-swamp-200 rounded-lg focus:ring-2 focus:ring-swamp-400 focus:border-transparent"
                       placeholder="General Question" />
                <span asp-validation-for="Input.Subject" class="text-red-600 text-sm"></span>
            </div>

            <div>
                <label asp-for="Input.Message" class="block text-sm font-medium text-swamp-700 mb-1">Your Message</label>
                <textarea asp-for="Input.Message"
                          rows="5"
                          class="w-full px-4 py-2 border border-swamp-200 rounded-lg focus:ring-2 focus:ring-swamp-400 focus:border-transparent"
                          placeholder="Type your message here..."></textarea>
                <span asp-validation-for="Input.Message" class="text-red-600 text-sm"></span>
            </div>

            <div class="text-center">
                <button type="submit"
                        class="bg-swamp-500 text-white px-8 py-3 rounded-full font-semibold hover:bg-swamp-600 transition-colors flex items-center justify-center space-x-2 mx-auto shadow-lg hover:shadow-swamp-200/50">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                    </svg>
                    <span>Send Message</span>
                </button>
            </div>
        </form>
    </div>
</section>
